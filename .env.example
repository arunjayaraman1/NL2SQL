# Database Registry
# Path to the JSON file listing the PostgreSQL databases the backend can connect
# to. Copy databases.example.json to databases.json and edit it.
DATABASES_CONFIG=./databases.json

# Shared PostgreSQL credentials referenced from databases.json via ${DB_USER}
# and ${DB_PASSWORD}. Adjust as needed; you can also hardcode per-database
# credentials in databases.json instead.
DB_USER=postgres
DB_PASSWORD=postgres

# OpenRouter LLM Configuration
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional override (defaults to https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter model IDs use provider/slug format, e.g. meta-llama/llama-3.3-70b-instruct
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# Cache TTL Settings (seconds)
PROFILE_CACHE_TTL=3600
COLUMN_CACHE_TTL=86400
LITERAL_CACHE_TTL=86400

# Optional: CORS origins (comma-separated)
# CORS_ALLOW_ORIGINS=http://localhost:3001,http://localhost:3000

# Optional: Include PostgreSQL dialect hints in LLM prompt
# NL2SQL_INCLUDE_DIALECT_HINTS=true
