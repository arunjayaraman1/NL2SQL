# Local run: localhost | Docker Compose: db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_MODEL=google/gemma-2-2b-it
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.7
NVIDIA_MAX_TOKENS=1024
# Optional: comma-separated origins for FastAPI CORS
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
# Optional: set to false to omit PostgreSQL dialect hints from the LLM prompt (see sql_prompt.py)
# NL2SQL_INCLUDE_DIALECT_HINTS=true